---
const windows = [
  {
    title: 'Composting.exe',
    content: 'I am unproven in the realm of growing stuff but I am great at making things rot.',
    color: '#00CC44',
  },
  {
    title: 'Reading.exe',
    content: '80/20 fiction:non-fiction. I go wide on genres but love books that have strong moral quandaries presented.',
    color: '#0066FF',
  },
  {
    title: 'Cooking.exe',
    content: 'Currently hyped about anything jalape\u00f1o and/or jerk chicken related.',
    color: '#CC2222',
  },
  {
    title: 'NOT Photography.exe',
    content: 'So please excuse the bad pictures & lack thereof.',
    color: '#CC8800',
  },
  {
    title: 'The Shed.exe',
    content: 'I am building an indoor playground area for my kids in our giant shed\u2122.',
    color: '#8844CC',
  },
];

const stickyNotes = [
  { text: 'TODO: Learn guitar', rotation: '-4deg', bg: '#FFFACD' },
  { text: 'Movie night Friday!', rotation: '3deg', bg: '#FFE4E1' },
  { text: 'Try that new recipe', rotation: '-2deg', bg: '#E0FFE0' },
];
---

<section id="hobbies" class="section hobbies-section">
  <div class="desktop-icons">
    <div class="desktop-icon">
      <div class="icon-img">📁</div>
      <span class="icon-label">My Hobbies</span>
    </div>
    <div class="desktop-icon">
      <div class="icon-img">🖥</div>
      <span class="icon-label">My Computer</span>
    </div>
    <div class="desktop-icon">
      <div class="icon-img">🗑</div>
      <span class="icon-label">Recycle Bin</span>
    </div>
  </div>

  <div class="container win-container">
    <h2 class="section-title hobbies-title">My Hobbies</h2>

    <div class="windows-grid">
      {windows.map((win, i) => (
        <div class="win-window" style={`--win-offset: ${i * 8}px`}>
          <div class="win-titlebar" style={`background: linear-gradient(90deg, ${win.color}, ${win.color}88)`}>
            <span class="win-titlebar-text">{win.title}</span>
            <div class="win-buttons">
              <button class="win-btn">_</button>
              <button class="win-btn">□</button>
              <button class="win-btn win-close">×</button>
            </div>
          </div>
          <div class="win-body">
            <p>{win.content}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="sticky-notes-area">
      {stickyNotes.map((note) => (
        <div class="sticky-note" style={`transform:rotate(${note.rotation});background:${note.bg}`}>
          <p>{note.text}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Taskbar at bottom of section -->
  <div class="section-taskbar">
    <div class="start-button win95-raised">
      <span class="start-flag">🪟</span>
      <span class="start-label">Start</span>
    </div>
    <div class="taskbar-tray">
      <span class="tray-item">🔊</span>
      <span class="tray-time">4:20 PM</span>
    </div>
  </div>
</section>

<style>
  .hobbies-section {
    background: var(--bg-teal);
    position: relative;
    padding-bottom: 80px;
  }

  .hobbies-title {
    color: white;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.4);
    margin-bottom: 32px;
  }

  .win-container {
    position: relative;
    z-index: 2;
  }

  /* Desktop icons */
  .desktop-icons {
    position: absolute;
    top: 60px;
    right: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 1;
  }

  .desktop-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: default;
  }

  .icon-img {
    font-size: 32px;
  }

  .icon-label {
    font-family: var(--font-ui);
    font-size: 11px;
    color: white;
    text-shadow: 1px 1px 0 #000;
    text-align: center;
  }

  /* Windows grid */
  .windows-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
  }

  .win-window {
    background: var(--bg-gray);
    border-top: 2px solid var(--win95-highlight);
    border-left: 2px solid var(--win95-highlight);
    border-bottom: 2px solid var(--win95-dark-shadow);
    border-right: 2px solid var(--win95-dark-shadow);
    box-shadow: 4px 4px 0 rgba(0,0,0,0.3);
  }

  .win-titlebar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 3px 4px;
    color: white;
  }

  .win-titlebar-text {
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 700;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.5);
    padding-left: 4px;
  }

  .win-buttons {
    display: flex;
    gap: 2px;
  }

  .win-btn {
    width: 18px;
    height: 18px;
    background: var(--bg-gray);
    border-top: 1px solid var(--win95-highlight);
    border-left: 1px solid var(--win95-highlight);
    border-bottom: 1px solid var(--win95-dark-shadow);
    border-right: 1px solid var(--win95-dark-shadow);
    font-size: 12px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-ui);
  }

  .win-close {
    color: #222;
    font-weight: bold;
  }

  .win-body {
    padding: 16px;
    background: white;
    margin: 2px;
    font-family: var(--font-body);
    font-size: 20px;
    color: #222;
    line-height: 1.5;
    border: 1px solid var(--win95-dark-shadow);
  }

  /* Sticky notes */
  .sticky-notes-area {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .sticky-note {
    width: 150px;
    padding: 16px;
    font-family: var(--font-body);
    font-size: 18px;
    box-shadow: 3px 3px 8px rgba(0,0,0,0.2);
    line-height: 1.4;
    text-align: center;
    color: #444;
  }

  /* Section taskbar */
  .section-taskbar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40px;
    background: var(--bg-gray);
    border-top: 2px solid var(--win95-highlight);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px;
    z-index: 3;
  }

  .start-button {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    background: var(--bg-gray);
    height: 28px;
    cursor: pointer;
  }

  .start-flag {
    font-size: 14px;
  }

  .start-label {
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 700;
  }

  .taskbar-tray {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 2px 8px;
    border-top: 1px solid var(--win95-dark-shadow);
    border-left: 1px solid var(--win95-dark-shadow);
    border-bottom: 1px solid var(--win95-highlight);
    border-right: 1px solid var(--win95-highlight);
    height: 28px;
  }

  .tray-item {
    font-size: 14px;
  }

  .tray-time {
    font-family: var(--font-body);
    font-size: 16px;
    color: #222;
  }

  @media (max-width: 640px) {
    .desktop-icons { display: none; }
    .windows-grid { grid-template-columns: 1fr; }
    .sticky-note { width: 130px; font-size: 16px; }
  }
</style>
