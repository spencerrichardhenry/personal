---
const handRaise = [
  'A vibe coding tool (Lovable, Bolt, v0)',
  'A coding tool (GitHub Copilot, Cursor, Windsurf)',
  'An agentic tool (Claude Code, Codex, Devin)',
  'Image/video gen tools (Sora, Midjourney, DALL-E)',
];
---

<section id="prep-qs" class="section prep-section">
  <div class="container">
    <h2 class="section-title prep-title">QUICK PULSE CHECK</h2>

    <div class="qs-list">
      <div class="q-card boxy-box">
        <div class="q-header">
          <span class="q-icon">🙋</span>
          <p class="q-text">Has everyone used an LLM chat before?</p>
        </div>
      </div>

      <div class="q-card boxy-box">
        <div class="q-header">
          <span class="q-icon">📅</span>
          <p class="q-text">In the past month?</p>
        </div>
      </div>

      <div class="q-card q-card-big boxy-box">
        <div class="q-header">
          <span class="q-icon">✋</span>
          <p class="q-text">Raise your hand if you've used:</p>
        </div>
        <div class="hand-raise-list">
          {handRaise.map((item) => (
            <div class="hand-raise-item">
              <span class="hand-raise-bullet">▸</span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .prep-section {
    background-color: var(--bg-light);
    background-image:
      linear-gradient(45deg, #e8e0d4 25%, transparent 25%),
      linear-gradient(-45deg, #e8e0d4 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #e8e0d4 75%),
      linear-gradient(-45deg, transparent 75%, #e8e0d4 75%);
    background-size: 40px 40px;
    background-position: 0 0, 0 20px, 20px -20px, -20px 0;
  }

  .prep-title {
    color: #222;
  }

  .qs-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 700px;
    margin: 0 auto;
  }

  .q-card {
    padding: 20px 24px;
  }

  .q-header {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .q-icon {
    font-size: 28px;
    flex-shrink: 0;
  }

  .q-text {
    font-family: var(--font-body);
    font-size: 24px;
    color: #333;
    line-height: 1.4;
  }

  .hand-raise-list {
    margin-top: 16px;
    padding-left: 46px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .hand-raise-item {
    display: flex;
    gap: 8px;
    align-items: baseline;
    font-family: var(--font-body);
    font-size: 22px;
    color: #444;
    line-height: 1.4;
  }

  .hand-raise-bullet {
    color: var(--blue);
    flex-shrink: 0;
  }
</style>
